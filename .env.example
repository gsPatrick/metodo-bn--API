# =====================================================================
# .env.example — todas as variáveis necessárias (SEM segredos reais).
# Copie para `.env` e preencha os valores do seu ambiente.
# Documentação completa: src/documentacao/ENV_REFERENCE.md
# =====================================================================

# --- Aplicação ---
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1
CORS_ORIGIN=*

# --- Banco de Dados (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=app_db
DB_USER=postgres
DB_PASSWORD=change-me
DB_SSL=false
# Alternativa: URL única (tem prioridade se preenchida)
# DATABASE_URL=postgres://user:password@localhost:5432/app_db

# --- Autenticação (JWT + Refresh + Reset) ---
JWT_SECRET=change-me-with-a-long-random-string
# Expiração do access token (curto). Ex: 15m, 1h
JWT_ACCESS_EXPIRES_IN=15m
# Expiração do refresh token (em dias)
REFRESH_TOKEN_EXPIRES_DAYS=30
# Validade do token de recuperação de senha (em minutos)
PASSWORD_RESET_EXPIRES_MIN=30
# Papéis aceitos no registro público (admin nunca é auto-criável)
ALLOWED_SELF_REGISTER_ROLES=nutritionist,patient

# --- Nutricionista padrão (criada no boot, se não existir) ---
DEFAULT_NUTRI_NAME=Nutricionista Beatriz Nascimento
DEFAULT_NUTRI_EMAIL=
DEFAULT_NUTRI_PASSWORD=

# --- E-mail (Resend) ---
RESEND_API_KEY=re_change_me
MAIL_FROM=App <no-reply@seu-dominio.com>
MAIL_REPLY_TO=
# URL do front para montar links (ex: reset de senha)
APP_WEB_URL=http://localhost:5173

# --- WebSocket (Socket.io) ---
WS_CORS_ORIGIN=*

# --- Gateway de Pagamento (Asaas / Stripe / Pagar.me) ---
PAYMENT_PROVIDER=asaas
PAYMENT_API_URL=https://sandbox.asaas.com/api/v3
PAYMENT_API_KEY=change-me
PAYMENT_WEBHOOK_SECRET=change-me

# --- Push Notifications (FCM / APNS) ---
FCM_SERVER_KEY=change-me

# --- IA (Anthropic / Claude) — montagem assistida de dieta ---
ANTHROPIC_API_KEY=sk-ant-change-me
AI_MODEL=claude-opus-4-8
AI_MAX_TOKENS=8000

# --- Cache de alimentos populares (em memória) ---
FOOD_CACHE_TTL_SECONDS=300
FOOD_POPULAR_LIMIT=50
