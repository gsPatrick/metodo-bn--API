{
  "name": "api",
  "version": "1.0.0",
  "description": "API Node.js + Express + Sequelize + PostgreSQL (RBAC, WebSockets, notificações e monetização)",
  "main": "app.js",
  "type": "commonjs",
  "scripts": {
    "start": "node app.js",
    "dev": "node --watch app.js",
    "migrate": "sequelize-cli db:migrate",
    "migrate:undo": "sequelize-cli db:migrate:undo",
    "seed": "sequelize-cli db:seed:all",
    "db:sync": "node scripts/db-sync.js --alter",
    "db:seed-foods": "node scripts/seed-foods.js",
    "smoke:test": "node scripts/smoke-test.js",
    "selfcheck:anamnesis": "node scripts/anamnesis-selfcheck.js",
    "selfcheck:nutrition": "node scripts/nutrition-selfcheck.js"
  },
  "keywords": [
    "express",
    "sequelize",
    "postgresql",
    "rbac",
    "websockets"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.12.0",
    "pg-hstore": "^2.3.4",
    "resend": "^4.0.0",
    "sequelize": "^6.37.3",
    "socket.io": "^4.7.5",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "sequelize-cli": "^6.6.2"
  }
}
